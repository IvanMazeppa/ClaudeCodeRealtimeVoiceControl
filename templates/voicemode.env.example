# Example voice-mode runtime settings.
# Do not store a live OPENAI_API_KEY in this file.
# Make OPENAI_API_KEY available in both Windows and WSL so
# Windows-side tools and WSL-side voice sessions can both use it.
# Example placeholder only:
# OPENAI_API_KEY=replace-with-your-openai-api-key

VOICEMODE_TTS_BASE_URLS=https://api.openai.com/v1
VOICEMODE_STT_BASE_URLS=https://api.openai.com/v1
VOICEMODE_VOICES=shimmer,nova,af_sky
VOICEMODE_TTS_MODELS=gpt-4o-mini-tts,tts-1-hd,tts-1
